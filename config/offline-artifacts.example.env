# Example/template only. Do not use this file as-is.
# Values are non-secret artifact coordinates, but logs and docs still avoid
# dumping them unnecessarily. Replace every URL, image digest, and sha256 with
# release artifacts you have intentionally pinned and verified.

K3S_BINARY_URL=https://example.invalid/k3s
K3S_BINARY_SHA256=<64-lowercase-hex-sha256>
K3S_INSTALL_SCRIPT_URL=https://example.invalid/install.sh
K3S_INSTALL_SCRIPT_SHA256=<64-lowercase-hex-sha256>
K3S_AIRGAP_IMAGES_URL=https://example.invalid/k3s-airgap-images-amd64.tar.zst
K3S_AIRGAP_IMAGES_SHA256=<64-lowercase-hex-sha256>

KUBECTL_BINARY_URL=https://example.invalid/kubectl
KUBECTL_BINARY_SHA256=<64-lowercase-hex-sha256>

JUICEFS_CSI_ARTIFACT_URL=https://example.invalid/juicefs-csi.tgz
JUICEFS_CSI_ARTIFACT_SHA256=<64-lowercase-hex-sha256>

POSTGRES_IMAGE=docker.io/library/postgres@sha256:<64-lowercase-hex-digest>
POSTGRES_ARCHIVE_URL=https://example.invalid/postgres-oci.tar
POSTGRES_ARCHIVE_SHA256=<64-lowercase-hex-sha256>

MINIO_IMAGE=quay.io/minio/minio@sha256:<64-lowercase-hex-digest>
MINIO_ARCHIVE_URL=https://example.invalid/minio-oci.tar
MINIO_ARCHIVE_SHA256=<64-lowercase-hex-sha256>

MINIO_CLIENT_IMAGE=quay.io/minio/mc@sha256:<64-lowercase-hex-digest>
MINIO_CLIENT_ARCHIVE_URL=https://example.invalid/minio-client-oci.tar
MINIO_CLIENT_ARCHIVE_SHA256=<64-lowercase-hex-sha256>

JUICEFS_CSI_IMAGE=docker.io/juicedata/juicefs-csi-driver@sha256:<64-lowercase-hex-digest>
JUICEFS_CSI_ARCHIVE_URL=https://example.invalid/juicefs-csi-oci.tar
JUICEFS_CSI_ARCHIVE_SHA256=<64-lowercase-hex-sha256>
