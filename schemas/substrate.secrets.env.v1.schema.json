{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsmith-lite.local/schemas/substrate.secrets.env.v1.schema.json",
  "title": "AgentSmith Lite substrate.secrets.env v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SUBSTRATE_SCHEMA_VERSION",
    "POSTGRES_APP_URL",
    "APP_SESSION_SECRET",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "JUICEFS_META_URL",
    "BUILTIN_ADMIN_INITIAL_PASSWORD",
    "OIDC_CLIENT_SECRET"
  ],
  "properties": {
    "SUBSTRATE_SCHEMA_VERSION": { "const": "agentsmith-lite.substrate.env/v1" },
    "POSTGRES_APP_URL": {
      "type": "string",
      "pattern": "^postgres(ql)?://",
      "description": "Product database URL; may be rendered into app-owned secrets."
    },
    "APP_SESSION_SECRET": {
      "type": "string",
      "minLength": 32,
      "description": "Product session signing/encryption secret."
    },
    "S3_ACCESS_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "Substrate/CSI scoped; do not inject into app workload env."
    },
    "S3_SECRET_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "Substrate/CSI scoped; do not inject into app workload env."
    },
    "JUICEFS_META_URL": {
      "type": "string",
      "pattern": "^postgres(ql)?://",
      "description": "Substrate/CSI scoped JuiceFS metadata URL."
    },
    "BUILTIN_ADMIN_INITIAL_PASSWORD": { "type": "string" },
    "OIDC_CLIENT_SECRET": {
      "type": "string",
      "description": "OIDC client secret when AUTH_MODE=oidc; empty when AUTH_MODE=builtin_admin."
    }
  }
}
