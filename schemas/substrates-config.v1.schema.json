{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsmith-lite.local/schemas/substrates-config.v1.schema.json",
  "title": "AgentSmith Lite substrates config v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["mode", "kubernetes", "objectStorage", "juicefs", "auth", "ingress"],
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": { "const": "existing-cloud" }
        },
        "required": ["mode"]
      },
      "then": {
        "required": ["postgres", "objectStorage"],
        "properties": {
          "postgres": {
            "required": ["appUrlFromEnv", "juicefsMetaUrlFromEnv"]
          },
          "objectStorage": {
            "required": ["accessKeyFromEnv", "secretKeyFromEnv"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "self-hosted" },
          "auth": {
            "properties": {
              "mode": { "const": "oidc" }
            },
            "required": ["mode"]
          }
        },
        "required": ["mode", "auth"]
      },
      "then": {
        "properties": {
          "auth": {
            "required": ["realm", "clientId", "keycloak"],
            "properties": {
              "keycloak": {
                "required": ["publicBaseUrl"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": { "const": "self-hosted" },
          "kubernetes": {
            "properties": {
              "skipK3s": { "const": true }
            },
            "required": ["skipK3s"]
          }
        },
        "required": ["mode", "kubernetes"]
      },
      "then": {
        "properties": {
          "kubernetes": {
            "required": ["kubeconfigPath"]
          }
        }
      }
    }
  ],
  "properties": {
    "mode": { "enum": ["self-hosted", "existing-cloud"] },
    "kubernetes": {
      "type": "object",
      "required": ["appNamespace", "substrateNamespace"],
      "properties": {
        "distribution": { "const": "k3s" },
        "appNamespace": { "type": "string", "minLength": 1 },
        "substrateNamespace": { "type": "string", "minLength": 1 },
        "skipK3s": { "type": "boolean" },
        "kubeconfigOutput": { "type": "string" },
        "kubeconfigPath": { "type": "string" },
        "context": { "type": "string" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "storageClass": { "type": "string" },
        "appDatabase": { "type": "string" },
        "juicefsDatabase": { "type": "string" },
        "appUrlFromEnv": { "type": "string", "minLength": 1 },
        "juicefsMetaUrlFromEnv": { "type": "string", "minLength": 1 }
      }
    },
    "objectStorage": {
      "type": "object",
      "required": ["provider", "bucket"],
      "properties": {
        "provider": { "enum": ["minio", "s3"] },
        "endpoint": { "type": "string" },
        "region": { "type": "string" },
        "bucket": { "type": "string", "minLength": 1 },
        "forcePathStyle": { "type": "boolean" },
        "accessKeyFromEnv": { "type": "string", "minLength": 1 },
        "secretKeyFromEnv": { "type": "string", "minLength": 1 }
      }
    },
    "juicefs": {
      "type": "object",
      "required": ["storageClass", "pvcName"],
      "properties": {
        "volumeName": { "type": "string" },
        "bucket": { "type": "string", "pattern": "^https?://[^\\s/?#]+/[^\\s/?#]+/?$" },
        "secretName": { "type": "string" },
        "csiDriver": { "const": "csi.juicefs.com" },
        "storageClass": { "type": "string", "minLength": 1 },
        "pvcName": { "type": "string", "minLength": 1 },
        "mountRoot": { "type": "string" }
      }
    },
    "modelProvider": {
      "type": "object",
      "properties": {
        "endpointSlug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "baseUrlFromEnv": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
        "apiKeyFromEnv": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "const": "oidc" },
        "realm": { "type": "string", "minLength": 1 },
        "clientId": { "type": "string", "minLength": 1 },
        "issuerUrlFromEnv": { "type": "string", "minLength": 1 },
        "clientIdFromEnv": { "type": "string", "minLength": 1 },
        "clientSecretFromEnv": { "type": "string", "minLength": 1 },
        "backchannelBaseUrlFromEnv": { "type": "string", "minLength": 1 },
        "bootstrapUsername": { "type": "string", "minLength": 1 },
        "keycloak": {
          "type": "object",
          "properties": {
            "publicBaseUrl": { "type": "string", "minLength": 1, "pattern": "^https?://" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["publicBaseUrl"],
      "properties": {
        "publicBaseUrl": { "type": "string", "minLength": 1 },
        "ingressClass": { "type": "string" },
        "tlsSecretName": { "type": "string" }
      }
    }
  }
}
