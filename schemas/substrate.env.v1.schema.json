{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsmith-lite.local/schemas/substrate.env.v1.schema.json",
  "title": "AgentSmith Lite substrate.env v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SUBSTRATE_SCHEMA_VERSION",
    "KUBE_NAMESPACE",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "AUTH_MODE",
    "JUICEFS_VOLUME_NAME",
    "JUICEFS_BUCKET",
    "JUICEFS_SECRET_NAME",
    "JUICEFS_CSI_DRIVER",
    "JUICEFS_STORAGE_CLASS",
    "JUICEFS_PVC_NAME",
    "JUICEFS_MOUNT_ROOT",
    "APP_PUBLIC_BASE_URL"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "AUTH_MODE": { "const": "builtin_admin" } },
        "required": ["AUTH_MODE"]
      },
      "then": {
        "properties": {
          "OIDC_ISSUER_URL": { "const": "" },
          "OIDC_CLIENT_ID": { "const": "" },
          "OIDC_BACKCHANNEL_BASE_URL": { "const": "" }
        }
      }
    },
    {
      "if": {
        "properties": { "AUTH_MODE": { "const": "oidc" } },
        "required": ["AUTH_MODE"]
      },
      "then": {
        "required": ["OIDC_ISSUER_URL", "OIDC_CLIENT_ID"],
        "properties": {
          "OIDC_ISSUER_URL": { "type": "string", "minLength": 1, "pattern": "^https?://[^\\s?#]+(/[^\\s?#]*)?$" },
          "OIDC_CLIENT_ID": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:-]+$" },
          "OIDC_BACKCHANNEL_BASE_URL": { "type": "string", "pattern": "^$|^https?://[^\\s?#]+(/[^\\s?#]*)?$" }
        }
      }
    }
  ],
  "properties": {
    "SUBSTRATE_SCHEMA_VERSION": { "const": "agentsmith-lite.substrate.env/v1" },
    "KUBECONFIG_PATH": { "type": "string" },
    "KUBE_CONTEXT": { "type": "string" },
    "KUBERNETES_SKIP_K3S": { "enum": ["true", "false"] },
    "KUBE_NAMESPACE": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "S3_ENDPOINT": { "type": "string", "pattern": "^https?://" },
    "S3_REGION": { "type": "string", "minLength": 1 },
    "S3_BUCKET": { "type": "string", "minLength": 3, "maxLength": 63, "pattern": "^(?![0-9]+(\\.[0-9]+){3}$)(?!.*\\.\\.)(?!.*\\.-)(?!.*-\\.)[a-z0-9][a-z0-9.-]*[a-z0-9]$" },
    "S3_FORCE_PATH_STYLE": { "enum": ["true", "false"] },
    "AUTH_MODE": { "enum": ["builtin_admin", "oidc"] },
    "OIDC_ISSUER_URL": { "type": "string" },
    "OIDC_CLIENT_ID": { "type": "string" },
    "OIDC_BACKCHANNEL_BASE_URL": { "type": "string" },
    "JUICEFS_VOLUME_NAME": { "type": "string", "minLength": 1 },
    "JUICEFS_BUCKET": { "type": "string", "pattern": "^https?://[^\\s/?#]+/[^\\s/?#]+/?$" },
    "JUICEFS_SECRET_NAME": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "JUICEFS_CSI_DRIVER": { "const": "csi.juicefs.com" },
    "JUICEFS_STORAGE_CLASS": { "type": "string", "minLength": 1, "maxLength": 253, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$" },
    "JUICEFS_PVC_NAME": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "JUICEFS_MOUNT_ROOT": { "type": "string", "pattern": "^/" },
    "APP_PUBLIC_BASE_URL": { "type": "string", "pattern": "^https?://" },
    "APP_INGRESS_CLASS": { "type": "string" },
    "APP_TLS_SECRET_NAME": { "type": "string" },
    "REGISTRY_URL": { "type": "string" },
    "IMAGE_PULL_SECRET_NAME": { "type": "string" }
  }
}
